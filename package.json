{
  "name": "modelica-json",
  "version": "1.3.1",
  "description": "Translating and exporting information from Modelica and CDL models to other formats: JSON, JSON-LD, HTML and DOCX.",
  "main": "app.js",
  "repository": "git.test_repo",
  "scripts": {
    "test": "nyc mocha --timeout 120000 && standard",
    "postinstall": "patch-package",
    "serve": "python3 -m http.server 8000",
    "generate-schema-js": "node -e \"const fs=require('fs'),d='schemaVisualization';fs.writeFileSync(d+'/schema-cdl.js','window.__CDL_SCHEMA__ = '+fs.readFileSync('schema-cdl.json','utf8')+';\\n');fs.writeFileSync(d+'/schema-modelica.js','window.__MODELICA_SCHEMA__ = '+fs.readFileSync('schema-modelica.json','utf8')+';\\n');console.log('Done: '+d+'/schema-cdl.js and '+d+'/schema-modelica.js');\"",
    "build-viz": "npm run generate-schema-js && node schemaVisualization/build-viz-html.js"
  },
  "author": "Michael Wetter",
  "license": "BSD-3-Clause",
  "dependencies": {
    "ajv": "^8.17.1",
    "antlr4": "4.7.2",
    "argparse": "^1.0.10",
    "array-unique": "^0.3.2",
    "bluebird": "^3.7.2",
    "cheerio": "^1.0.0",
    "cross-spawn": "^7.0.6",
    "express": "^4.19.2",
    "find": "^0.2.9",
    "fs": "0.0.1-security",
    "fs-extra": "^5.0.0",
    "glob": "^7.2.3",
    "glob-promise": "^3.4.0",
    "help": "^3.0.2",
    "load-json-file": "^4.0.0",
    "mathjs": "^11.12.0",
    "minimist": "^1.2.8",
    "mustache": "^2.3.2",
    "n3": "^1.17.4",
    "nyc": "^18.0.0",
    "promise-fs": "^1.3.0",
    "rdf-parse": "2.3.3",
    "rdflib": "^2.3.9",
    "streamify-string": "^1.0.1",
    "winston": "^2.4.5"
  },
  "devDependencies": {
    "chai": "^4.4.1",
    "mocha": "^11.3.0",
    "patch-package": "^8.0.1",
    "rewire": "^7.0.0",
    "sinon": "^15.2.0",
    "standard": "^17.1.2"
  },
  "standard": {
    "ignore": [
      "jsParser/antlrFiles/*",
      "jsParser/domain/*",
      "jsParser/parser/*"
    ]
  },
  "mocha": {
    "ignore": [
      "jsParser/antlrFiles/*"
    ]
  },
  "nyc": {
    "exclude": [
      "jsParser/antlrFiles/*"
    ]
  }
}
